#include <stdio.h>
/**
 * main - entry point
 *
 * description - prints no.s of base 16 in lowercase
 *
 * Return: Always 0.
 */
int main(void)
{
	int sixteen;

	char lowercase;

	for (sixteen = 0; sixteen < 10; sixteen++)
		putchar((sixteen % 10) + '0');

	for (lowercase = 'a'; lowercase <= 'f'; lowercase++)
		putchar(lowercase);

	putchar('\n');

	return (0);
}
